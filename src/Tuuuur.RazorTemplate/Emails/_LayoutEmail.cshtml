<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>@ViewData["Title"] - Tuuuur</title>
  <style>
    body {
      margin:0;
      padding:0;
      font-family: Arial, Helvetica, sans-serif;
      color: #E1E5E9;
    }
  </style>
</head>
<body>
<table width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td align="center" style="padding:20px;">

      <!-- Container principal -->
      <table width="600" cellpadding="0" cellspacing="0" bgcolor="#1A1B2E" style="border-radius:10px;">

        <!-- Header -->
        <tr>
          <td align="center" bgcolor="#6C5CE7" style="padding:25px; color:#FFFFFF;">
            <img src="cid:LogoImage" alt="Tuuuur Logo" width="100" style="display:block; margin-bottom:10px; border:0;">
            <h1 style="margin:0; font-size:26px; color:#FFFFFF;">Tuuuur</h1>
            <p style="margin:5px 0 0 0; font-size:14px; color:#FFFFFF;">Quiz • Fun • Compétition</p>
          </td>
        </tr>

        <tr>
            @RenderBody()
        </tr>

        <tr>
          <td align="center" style="padding:20px; font-size:12px; color:#8B9AA8; border-top:1px solid #6C5CE7;">
            © @DateTime.Now.Year Tuuuur – Tous droits réservés
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
</body>
</html>
