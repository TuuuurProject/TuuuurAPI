{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Tuuuur": ""
  },
  "JwtSettings": {
    "Issuer": "https://localhost:44369/",
    "Audience": "https://localhost:44369/",
    "Validity": 60,
    "Key": ""
  },
  "Authentification": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\Local\\Tuuuur\\Logs\\backofficelogs-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.ffff}|{RequestId}|{SourceContext}|{Level:u3}|{Properties:j}|{Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Tuuuur API"
    }
  }
}