{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Tuuuur": "",
    "Redis": ""
  },
  "SmtpEmailConfiguration": {
    "FromAddress": "",
    "FromName": "",
    "SmtpAddress": "",
    "SmtpPort": 0,
    "SmtpLogin": "",
    "SmtpPassword": ""
  },
  "JwtSettings": {
    "Issuer": "https://localhost:44369/",
    "Audience": "https://localhost:44369/",
    "Validity": 60,
    "Key": ""
  },
  "Authentification": {
    "Google": {
      "ClientId": ""
    }
  },
  "CalculConfiguration": {
    "MaxDurationInSeconds": 30,
    "MaxScore": 1000
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.ffff}|{Level:u3}|{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/backofficelogs-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "Tuuuur API"
    }
  }
}